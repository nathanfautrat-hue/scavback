{
  "name": "Order",
  "type": "object",
  "properties": {
    "order_number": {
      "type": "string"
    },
    "user_email": {
      "type": "string"
    },
    "user_name": {
      "type": "string"
    },
    "prenom": {
      "type": "string"
    },
    "nom": {
      "type": "string"
    },
    "adresse": {
      "type": "string"
    },
    "complement": {
      "type": "string"
    },
    "pays": {
      "type": "string"
    },
    "ville": {
      "type": "string"
    },
    "code_postal": {
      "type": "string"
    },
    "services": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quantity": {
      "type": "number"
    },
    "total": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "paid",
        "in_progress",
        "delivered"
      ],
      "default": "pending"
    }
  },
  "required": [
    "order_number",
    "user_email",
    "services",
    "total"
  ]
}