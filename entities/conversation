{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "order_id": {
      "type": "string"
    },
    "order_number": {
      "type": "string"
    },
    "client_email": {
      "type": "string"
    },
    "client_name": {
      "type": "string"
    },
    "message_count": {
      "type": "number",
      "default": 0
    },
    "last_message_date": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "closed"
      ],
      "default": "active"
    },
    "feedback": {
      "type": "object",
      "properties": {
        "rating": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "submitted_date": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "required": [
    "order_id",
    "order_number",
    "client_email"
  ]
}